{
  "name": "@rhizomatics/signalk-datalab-plugin",
  "version": "0.2.0",
  "signalk": {
    "displayName": "Data Lab"
  },
  "description": "Interactive data analysis notebooks for SignalK, running as WebAssembly in the browser",
  "main": "dist/index.js",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "signalk-category-data",
    "marimo",
    "notebooks",
    "marine-data"
  ],
  "scripts": {
    "build:ts": "tsc",
    "build:wasm": "uv run --with marimo marimo export html-wasm notebooks/signalk.py -o public/ --mode edit -f && cp notebooks/CLAUDE.md notebooks/logo.png public/",
    "build": "npm run build:ts && npm run build:wasm",
    "watch": "tsc --watch",
    "prepare": "npm run build"
  },
  "files": [
    "dist/",
    "public/",
    "notebooks/"
  ],
  "dependencies": {
    "@signalk/server-api": "^2.22.0",
    "express": ">=4"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "license": "APACHE-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeyrb/signalk-datalab.git"
  },
  "author": "jey burrows",
  "type": "commonjs",
  "types": "./dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/jeyrb/signalk-datalab/issues"
  },
  "homepage": "https://github.com/jeyrb/signalk-datalab#readme"
}
